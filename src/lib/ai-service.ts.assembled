            throw new CareerForgeError('JSON_PARSE_ERROR', 'Failed strict balanced validation requirements after retry.');
          }
        }
      } else {
        if (!parsed || !parsed.fullName) {
      } else {
        if (!parsed || !parsed.fullName) {
          throw new CareerForgeError('JSON_PARSE_ERROR', 'Invalid premium resume data');
        }
      }
      return parsed as EnhancedResumeResult | LeadershipResumeResult | BalancedResumeResult;
    } catch (err) {
      console.warn(`[CareerForge] Premium ${variant} resume failed, falling back to basic:`, err);
      const fallback = await AIService.enhanceResumeData(careerProfile, apiKey);
      
      if (variant === 'leadership') {
         return LeadershipValidationLayer.upgrade(fallback, careerProfile);
      } else if (variant === 'balanced') {
         return BalancedValidationLayer.upgrade(fallback, careerProfile);
      }
      return fallback;
    } resume failed, falling back to basic:`, err);
      const fallback = await AIService.enhanceResumeData(careerProfile, apiKey);
      
      if (variant === 'leadership') {
         return {
           ...fallback,
           title: careerProfile.professionCategory || "Professional",
           professionalProfile: fallback.summary || "",
           coreCompetencies: {
             technical: fallback.skills ? fallback.skills.slice(0, 6) : ["JavaScript", "React", "Node.js"],
             leadership: ["Project Management", "Communication", "Team Coordination", "Problem Solving"]
           },
           experience: fallback.experience ? fallback.experience.map(e => ({
             ...e,
             achievements: (e as any).achievements || e.highlights || []
           })) : [],
           projects: fallback.projects ? fallback.projects.map(p => ({
             title: p.title,
             overview: p.description || "",
             achievements: (p as any).achievements || p.highlights || [],
             techStack: p.techStack || [],
             link: p.link,
           })) : []
         } as BalancedResumeResult;
      }
      return fallback;
    }
  },

