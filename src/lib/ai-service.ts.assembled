function parseJsonSafely<T>(raw: string, label: string): T | null {
  try {
    // Strip markdown code fences if present
    const cleaned = raw
      .replace(/^```json\s*/i, '')
      .replace(/^```\s*/i, '')
      .replace(/```\s*$/i, '')
      .trim();
    return JSON.parse(cleaned) as T;
  } catch (err) {
    console.error(`[CareerForge] JSON_PARSE_ERROR in ${label}:`, err);
      if (ans.responsibilities) achievements.push(`Core responsibilities: ${ans.responsibilities}`);
      if (ans.processImproved) achievements.push(`Improved workflow: ${ans.processImproved}`);
      return { ...exp, achievements };
    });
  }

  return enhanced;
}

