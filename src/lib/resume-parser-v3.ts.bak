/**
 * resume-parser.ts  —  v3 (Hierarchical Architecture)
 * CareerForge deterministic resume parser.
 *
 * Pipeline:
 *  Phase 1 – Text Normalization   (merge PDF wraps, unicode bullets, whitespace)
 *  Phase 2 – Contact Extraction   (independent; never depends on section detection)
 *  Phase 3 – Section Detection    (boundary mapping; strict header matching)
 *  Phase 4 – Hierarchical Parsing (skills, experience, projects, education, certs)
 *  Phase 5 – Confidence Engine    (per-field scoring)
 *  Phase 6 – Debug Diagnostics    (dev mode only)
 *
 * Critical rules:
 *  - NEVER generate placeholder data
 *  - If confidence is low, leave field empty — never invent content
 *  - Projects are hierarchical: title → description → bullets → tech
 *  - Bullets ALWAYS belong to the nearest project/experience above them
 *  - Section leakage is not allowed
 */

import { ProfessionCategory } from '@/db/local-db';
import { devLog } from './model-config';

// ─────────────────────────────────────────────────────────────────────────────
// TYPES
// ─────────────────────────────────────────────────────────────────────────────

export interface ParsedEducation {
  institution: string;
  degree: string;
  fieldOfStudy?: string;
  startDate?: string;
  endDate?: string;
  grade?: string;
}

export interface ParsedExperience {
  company: string;
  position: string;
  location?: string;
  startDate?: string;
  endDate?: string;
  current: boolean;
  highlights: string[];
}

export interface ParsedProject {
  title: string;
  description: string;
  techStack?: string[];
  link?: string;
  highlights: string[];
  problemSolved?: string;
  keyImpact?: string;
}

export interface ConfidenceScores {
  fullName: number;
  email: number;
  phone: number;
  location: number;
  skills: number;
  education: number;
  experience: number;
  projects: number;
  certifications: number;
  overall: number;
}

export interface ParserDebugInfo {
  sectionsDetected: string[];
  sectionBoundaries: { name: string; startLine: number; endLine: number }[];
  projectTitlesAccepted: string[];
  projectTitlesRejected: { line: string; reason: string }[];
  experienceEntriesDetected: number;
  educationEntriesDetected: number;
  totalNormalizedLines: number;
}

export interface ParsedResumeResult {
  fullName: string;
  email: string;
  phone: string;
  location: string;
  summary?: string;
  website?: string;
  github?: string;
  linkedin?: string;
  skills: string[];
  education: ParsedEducation[];
  experience: ParsedExperience[];
  projects: ParsedProject[];
  certifications: string[];
  achievements: string[];
  publications: string[];
  workSamples: { title: string; url: string; description?: string }[];
  confidenceScores: ConfidenceScores;
  rawText: string;
  extractedAt: string;
  originalFileName?: string;
  isPartialExtraction: boolean;
  parserDebug?: ParserDebugInfo;
}

