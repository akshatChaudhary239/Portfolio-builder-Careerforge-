         return {
           ...fallback,
           title: careerProfile.professionCategory || "Professional",
           professionalProfile: fallback.summary || "",
           coreCompetencies: {
             technical: fallback.skills ? fallback.skills.slice(0, 6) : ["JavaScript", "React", "Node.js"],
             leadership: ["Project Management", "Communication", "Team Coordination", "Problem Solving"]
           },
           experience: fallback.experience ? fallback.experience.map(e => ({
             ...e,
             achievements: (e as any).achievements || e.highlights || []
           })) : [],
           projects: fallback.projects ? fallback.projects.map(p => ({
             title: p.title,
             overview: p.description || "",
             achievements: (p as any).achievements || p.highlights || [],
             techStack: p.techStack || [],
             link: p.link,
           })) : []
         } as BalancedResumeResult;
      }
      return fallback;
    }
  },

